# FundRequest — Environment Variables
# Copy file ini dan isi nilainya:
#   cp .env .env.local

# JWT Secret — ganti dengan string acak minimal 32 karakter
JWT_SECRET=ganti_dengan_secret_yang_kuat_minimal_32_karakter

# Database path (default: ./data/fundrequest.db)
# DATABASE_PATH=/app/data/fundrequest.db

# Port backend (default: 8787)
# PORT=8787
